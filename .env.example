# Copy this file to `.env` and fill in the values from your local Supabase stack.
# `supabase start` prints the API URL and the anon key; or read them from `supabase status`.
# NEVER commit `.env` (it is git-ignored). Only variable NAMES belong in this file.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Wave 5 (reference-overlays) ---
# OPTIONAL. The ZIP / ZCTA boundary overlay reads its vector-tile source ONLY
# from this variable (token rides in the URL — NEVER hardcode it in source).
# When UNSET, the ZIP toggle ships disabled with a helper note (graceful
# degrade) — the capitals/metros/vertical layers work with zero setup.
# Point it at a TileJSON or pmtiles:// URL for a ZCTA5 vector tileset whose
# source-layer is named `zcta`. See docs/zcta-tiles-setup.md for the build.
VITE_ZCTA_TILES_URL=
